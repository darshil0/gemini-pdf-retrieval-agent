# DocuSearch Agent Environment Configuration
# Copy this file to .env and fill in your values

# ==================================
# REQUIRED: Google Gemini API Key
# ==================================
# Get your API key from: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# ==================================
# OPTIONAL: AI Model Settings
# ==================================
# The Gemini model to use (default: gemini-1.5-flash)
VITE_GEMINI_MODEL="gemini-1.5-flash"

# ==================================
# OPTIONAL: Application Settings
# ==================================

# Maximum file size in bytes (default: 200MB)
VITE_MAX_FILE_SIZE=209715200

# Maximum number of files allowed (default: 10)
VITE_MAX_FILES=10

# API rate limit in requests per minute (default: 10)
VITE_RATE_LIMIT=10

# API timeout in milliseconds (default: 60000)
VITE_API_TIMEOUT_MS=60000

# ==================================
# OPTIONAL: PDF Viewer Settings
# ==================================
# Custom path/CDN for PDF.js worker. Defaults to unpkg.com if not set.
# Example: https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.449/pdf.worker.min.mjs
VITE_PDF_WORKER_SRC=""

# ==================================
# OPTIONAL: Development & Observability
# ==================================

# Development server port (default: 5173)
VITE_PORT=5173

# Enable structured debug logging in browser console (default: false)
VITE_DEBUG=false

# ==================================
# OPTIONAL: Feature Flags
# ==================================

# Enable fuzzy search (default: true)
VITE_ENABLE_FUZZY_SEARCH=true

# Enable semantic search (default: true)
VITE_ENABLE_SEMANTIC_SEARCH=true

# ==================================
# NOTES
# ==================================
# - Never commit your actual .env file with real values
# - Keep your API key secure
# - Restart the development server after changing values
# - Boolean values: true/false
# - Numbers: don't use quotes
