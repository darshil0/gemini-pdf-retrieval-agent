# DocuSearch Agent Environment Configuration
# Copy this file to .env and fill in your values

# ==================================
# REQUIRED: Google Gemini API Key
# ==================================
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# ==================================
# OPTIONAL: Application Settings
# ==================================
VITE_MAX_FILE_SIZE=209715200
VITE_MAX_FILES=10
VITE_RATE_LIMIT=10

# ==================================
# OPTIONAL: Development Settings
# ==================================
VITE_PORT=5173
VITE_DEBUG=false

# ==================================
# OPTIONAL: Feature Flags
# ==================================
VITE_ENABLE_FUZZY_SEARCH=true
VITE_ENABLE_SEMANTIC_SEARCH=true

# ==================================
# NOTES
# ==================================
# - Never commit your real .env file to version control.
# - Restart your development server (npm run dev) after updating these values.
# - No quotes needed for simple strings, numbers, or booleans.
